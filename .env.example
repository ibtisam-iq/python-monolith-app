# ──────────────────────────────────────────────────────────────────────────────
# Environment variable template — safe to commit.
# Copy this file to .env and fill in your actual values before running.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL credentials
# These values are used by both the 'db' service and the DATABASE_URL
# connection string passed to the Flask 'app' service in compose.yml.
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=flask_db

# Full database connection URL — assembled from the above credentials.
# For Docker Compose: host is the service name 'db' (Docker internal DNS).
# For local bare-metal run: replace 'db' with 'localhost'.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Flask server port (must match EXPOSE in Dockerfile and ports in compose.yml)
PORT=5000
