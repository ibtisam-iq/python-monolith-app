# ──────────────────────────────────────────────────────────────────────────────
# Environment variable template — safe to commit.
# Copy this file to .env and fill in your actual values before running.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL Credentials ────────────────────────────────────────────────────
# Used by:
#   - The 'db' service in compose.yml to initialize the PostgreSQL container.
#   - The DATABASE_URL below to build the full connection string.
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=flask_db

# ── Database Connection URL ────────────────────────────────────────────────────
# This is the single value read by config.py to connect Flask to PostgreSQL.
#
# STRATEGY: Keep ONE .env file for ALL environments. Never maintain separate files.
# The host part ('localhost' vs 'db') is the only thing that changes per environment
# — and for Docker Compose, that change is handled automatically in compose.yml
# via an environment block override. So this file always stays with 'localhost'.
#
# HOW IT WORKS PER ENVIRONMENT:
#
#   1. Bare-metal (python run.py):
#      - python-dotenv reads this file and passes DATABASE_URL directly to Flask.
#      - python-dotenv does NOT expand ${...} shell variables.
#      - So literal values are required here. 'localhost' is correct.
#
#   2. Docker Compose (docker compose up):
#      - compose.yml loads this file via 'env_file: .env'.
#      - BUT compose.yml also has an 'environment' block on the 'app' service
#        that OVERRIDES DATABASE_URL with '@db:5432' — 'db' being the PostgreSQL
#        service name that Docker resolves as a hostname on the internal network.
#      - So the value below is NEVER used by Docker Compose for the app container.
#        It is effectively ignored — compose.yml always wins for DATABASE_URL.
#
# CONCLUSION: Always write DATABASE_URL with literal values pointing to localhost.
# You never need to change this file when switching between bare-metal and Docker Compose.
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/flask_db

# ── Flask Server Port ────────────────────────────────────────────────────────
# Used by run.py for bare-metal runs.
# In compose.yml, this value controls the HOST port mapping: "${PORT:-5000}:5000".
# The container always listens on 5000 (hardcoded in Dockerfile CMD and EXPOSE).
PORT=5000
