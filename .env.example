# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values before running.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL credentials
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=flask_db

# Full database connection URL.
#
# IMPORTANT: python-dotenv does NOT expand ${...} shell variables.
# Always write DATABASE_URL with literal values, not variable references.
#
# For bare-metal local runs (PostgreSQL on your machine):
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/flask_db

# For Docker Compose: uncomment the line below and comment out the one above.
# Docker Compose DOES expand ${...} and resolves 'db' as the PostgreSQL service name.
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Flask server port (must match EXPOSE in Dockerfile and ports in compose.yml)
PORT=5000
