# Git
.git
.gitignore
.gitattributes
.gitmodules

# Python
__pycache__
*.py[cod]
*.pyo
.venv
venv
*.egg-info
dist
build

# Tests
tests/

# IDE and editor files
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store

# Environment files — NEVER bake secrets into images
.env
.env.*
!.env.example            # Exception: allow the example template (no real secrets)

# Docker files themselves (not needed inside the image)
Dockerfile
compose.yml
.dockerignore

# Documentation and assets (not needed at runtime)
README.md
docs/
assets/
.scratchpad/

# Test and coverage reports
*.log
