# ──────────────────────────────────────────────────────────────────────────────
# Local development environment variables.
# DO NOT commit real secrets to version control.
# This file is listed in .gitignore — it is safe for local use only.
# For CI/CD, inject these as pipeline secrets or environment variables.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL credentials
# These values are used by both the 'db' service and the DATABASE_URL
# connection string passed to the Flask 'app' service in compose.yml.
POSTGRES_USER=ibtisam
POSTGRES_PASSWORD=ibtisam
POSTGRES_DB=flask_db

# Flask server port (must match EXPOSE in Dockerfile and ports in compose.yml)
PORT=5000
